  "required_episode_structure": {
    "problem": true,
    "context": true,
    "big_picture": {
      "label": "Big Picture",
      "time_label": "30 sec",
      "job": "Recognition and immediate utility",
      "required": [
        "one visual insight",
        "one surprising or commonly missed fact",
        "one costly or consequential mistake",
        "one immediate action",
        "minimal prose"
      ]
    },
    "brief_overview": {
      "label": "Brief Overview",
      "time_label": "2 min",
      "job": "Practical understanding",
      "required": [
        "decision framework",
        "checklist or decision tree",
        "comparison",
        "simple physician-specific worked example",
        "no filler"
      ]
    },
    "deep_dive": {
      "label": "Deep Dive",
      "time_label": "5 min",
      "job": "Execution",
      "required": [
        "calculator or interactive tool where appropriate",
        "downloadable checklist",
        "scripts or questions to ask",
        "templates or illustrative language where appropriate",
        "common mistakes",
        "risks and limitations",
        "references",
        "action plan",
        "optional outcome plan"
      ]
    },
    "ending": {
      "know": "What did I learn?",
      "do": "What should I do next?",
      "share": "Who else should see this?"
    }
  },
