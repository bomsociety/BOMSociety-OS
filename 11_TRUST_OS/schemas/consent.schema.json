{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$id": "https://schemas.bomsociety.example/btos/v1/consent.schema.json",
  "title": "BTOS Consent",
  "properties": {
    "consent_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_:-]{3,128}$"
    },
    "subject_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_:-]{3,128}$"
    },
    "purpose": {
      "type": "string"
    },
    "status": {
      "enum": [
        "granted",
        "withdrawn",
        "expired",
        "not_required"
      ]
    },
    "legal_basis": {
      "type": "string"
    },
    "notice_version": {
      "type": "string"
    },
    "granted_at": {
      "type": "string",
      "format": "date-time"
    },
    "withdrawn_at": {
      "type": "string",
      "format": "date-time"
    },
    "jurisdiction": {
      "type": "string"
    }
  },
  "required": [
    "consent_id",
    "subject_id",
    "purpose",
    "status",
    "legal_basis",
    "jurisdiction"
  ]
}
