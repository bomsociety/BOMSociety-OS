{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$id": "https://schemas.bomsociety.example/btos/v1/identity.schema.json",
  "title": "BTOS Identity",
  "properties": {
    "subject_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_:-]{3,128}$"
    },
    "subject_type": {
      "enum": [
        "anonymous",
        "person",
        "organization",
        "service_account",
        "ai_agent"
      ]
    },
    "status": {
      "enum": [
        "active",
        "suspended",
        "revoked",
        "deleted"
      ]
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "tenant_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_:-]{3,128}$"
    },
    "jurisdiction": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "privacy_classification": {
      "type": "string"
    }
  },
  "required": [
    "subject_id",
    "subject_type",
    "status",
    "created_at",
    "privacy_classification"
  ]
}
