{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$id": "https://schemas.bomsociety.example/btos/v1/trust-score.schema.json",
  "title": "BTOS Trust-Score",
  "properties": {
    "subject_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_:-]{3,128}$"
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_version": {
      "type": "string"
    },
    "trust_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "factors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "direction": {
            "enum": [
              "positive",
              "negative",
              "neutral"
            ]
          },
          "weight": {
            "type": "number"
          }
        },
        "required": [
          "name",
          "direction"
        ],
        "additionalProperties": false
      }
    },
    "eligibility": {
      "type": "object"
    }
  },
  "required": [
    "subject_id",
    "evaluated_at",
    "policy_version",
    "trust_score"
  ]
}
