{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$id": "https://schemas.bomsociety.example/btos/v1/verification.schema.json",
  "title": "BTOS Verification",
  "properties": {
    "verification_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_:-]{3,128}$"
    },
    "subject_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_:-]{3,128}$"
    },
    "claim_type": {
      "enum": [
        "identity",
        "professional",
        "license",
        "organization"
      ]
    },
    "status": {
      "enum": [
        "pending",
        "verified",
        "rejected",
        "expired",
        "revoked",
        "manual_review"
      ]
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "connector_id": {
          "type": "string"
        },
        "connector_version": {
          "type": "string"
        },
        "authority": {
          "type": "string"
        }
      },
      "required": [
        "connector_id"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_:-]{3,128}$"
      }
    },
    "integrity_hash": {
      "type": "string"
    }
  },
  "required": [
    "verification_id",
    "subject_id",
    "claim_type",
    "status",
    "confidence",
    "issued_at"
  ]
}
