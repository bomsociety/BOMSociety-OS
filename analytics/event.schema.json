{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bomsociety.org/schemas/analytics-event-v1.json",
  "title": "BOMSociety Canonical Analytics Event", "type": "object",
  "required": ["schemaVersion","eventId","type","version","occurredAt","trace","actor","consent","context","properties"],
  "properties": {
    "schemaVersion": {"const": 1}, "eventId": {"type":"string","format":"uuid"},
    "type": {"enum":["page_view","section_view","scroll_depth","reading_depth_selected","article_complete","decision_path_started","decision_path_step","decision_path_completed","search_submitted","search_no_results","newsletter_attributed","newsletter_signup","member_verified"]},
    "version":{"type":"integer","minimum":1}, "occurredAt":{"type":"string","format":"date-time"},
    "trace":{"type":"object","required":["traceId","sessionId"],"properties":{"traceId":{"type":"string","format":"uuid"},"sessionId":{"type":"string","format":"uuid"}}},
    "actor":{"type":"object","required":["kind","anonymousId"],"properties":{"kind":{"enum":["anonymous","verified_member"]},"anonymousId":{"type":"string","format":"uuid"}},"not":{"required":["memberId"]}},
    "consent":{"enum":["granted","denied","unknown"]}, "context":{"type":"object","required":["path"],"properties":{"path":{"type":"string","pattern":"^/"}}}, "properties":{"type":"object"}
  }, "additionalProperties": false
}
