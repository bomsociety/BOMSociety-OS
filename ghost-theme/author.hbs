{{!< default}}
<section class="section">
  <div class="wrap">
    {{#author}}
      <p class="eyebrow">AUTHOR</p>
      <h1>{{name}}</h1>
      {{#if bio}}<p class="archive-description">{{bio}}</p>{{/if}}
    {{/author}}
    <div class="ghost-card-grid">{{#foreach posts}}{{> article-card}}{{/foreach}}</div>
    {{pagination}}
  </div>
</section>
