{{!< default}}
<!-- BOMSOCIETY-SPRINT-17B-CANONICAL: stable deployment marker -->
<main class="sprint17-home os-home" id="main" data-bomsociety-home="BOMSOCIETY-HOMEPAGE-V3" data-compensation-pathway>
  <section class="os-hero" aria-labelledby="os-title" data-track-section="homepage_hero">
    <div class="shell">
      <p class="os-mission">A private place to make the career decision in front of you.</p>
      <h1 id="os-title">Make the next career decision clearer.</h1>
      <div class="os-chooser" aria-labelledby="diagnosis-title" data-win-reveal>
        <div class="os-chooser-head"><p class="os-eyebrow">SOLVE A DECISION</p><h2 id="diagnosis-title">What needs a clearer answer today?</h2><p>Choose a pathway. You will see a useful next step immediately.</p></div>
        <div class="os-decision-grid" role="list">
          <button type="button" class="is-available" data-decision="Compensation" data-availability="available" data-source="hero" role="listitem"><span class="os-icon" aria-hidden="true">$</span><span><b>AVAILABLE NOW</b><strong>Compensation</strong><small>Know the formula behind the offer</small></span><em>Solve compensation now <i aria-hidden="true">→</i></em></button>
          <button type="button" data-decision="Contract" data-availability="coming_next" data-source="hero" role="listitem"><span class="os-icon" aria-hidden="true">⌁</span><span><b>COMING NEXT</b><strong>Contract</strong><small>See what shapes your options</small></span><em>Tell us your question <i aria-hidden="true">→</i></em></button>
          <button type="button" data-decision="Artificial Intelligence" data-availability="coming_next" data-source="hero" role="listitem"><span class="os-icon" aria-hidden="true">◌</span><span><b>COMING NEXT</b><strong>Artificial Intelligence</strong><small>Adopt with practical judgment</small></span><em>Tell us your question <i aria-hidden="true">→</i></em></button>
          <button type="button" data-decision="Practice Ownership" data-availability="coming_next" data-source="hero" role="listitem"><span class="os-icon" aria-hidden="true">◇</span><span><b>COMING NEXT</b><strong>Practice Ownership</strong><small>Compare the tradeoffs clearly</small></span><em>Tell us your question <i aria-hidden="true">→</i></em></button>
          <button type="button" data-decision="Leadership" data-availability="coming_next" data-source="hero" role="listitem"><span class="os-icon" aria-hidden="true">↗</span><span><b>COMING NEXT</b><strong>Leadership</strong><small>Lead the next conversation</small></span><em>Tell us your question <i aria-hidden="true">→</i></em></button>
        </div>
        <form class="os-describe" data-situation-form><label for="situation">Or describe my situation</label><div><input id="situation" name="situation" placeholder="Describe the decision you are facing…" autocomplete="off"><button class="os-button" type="submit">Show my next step <span aria-hidden="true">→</span></button></div></form>
      </div>
    </div>
  </section>

  <section class="os-momentum os-momentum-compact" aria-labelledby="momentum-title"><div class="shell"><div class="os-momentum-card"><div><p class="os-eyebrow">YOUR DECISION MOMENTUM</p><h2 id="momentum-title" data-momentum-title>Your first career win is ready.</h2><p data-momentum-copy>Start with one question that changes the compensation conversation.</p><small>Private progress. Useful next steps.</small></div><a class="os-button" href="#compensation-pathway" data-momentum-action>Show me the first step <span aria-hidden="true">→</span></a></div></div></section>

  <section class="os-first-win" aria-labelledby="first-win-title" data-track-section="first_career_win"><div class="shell os-first-win-grid"><div><p class="os-eyebrow">A USEFUL START · 30 SECONDS</p><h2 id="first-win-title">A compensation number is not a compensation formula.</h2><p>Before you weigh an offer, ask for the written formula, its threshold, and two recent reconciliation statements.</p></div><div class="os-first-win-action"><span aria-hidden="true">01</span><strong>One request can change the whole conversation.</strong><button type="button" class="os-text-link" data-library-decision="Compensation" data-availability="available">Use this framework <span aria-hidden="true">→</span></button></div></div></section>

  <section class="os-streams" aria-labelledby="library-title" data-track-section="decision_library"><div class="shell"><p class="os-eyebrow">DECISION LIBRARY</p><h2 id="library-title">Choose the next decision to make clearer.</h2><div class="os-stream-grid">
    <article><b>AVAILABLE NOW</b><h3>Compensation</h3><p>Understand the formula, test the offer, and identify your next step.</p><button type="button" class="os-text-link" data-library-decision="Compensation" data-availability="available">Show me the first step <span aria-hidden="true">→</span></button></article>
    <article><b>COMING NEXT</b><h3>Contract</h3><p>Terms, leverage, and choices.</p><button type="button" class="os-text-link" data-library-decision="Contract" data-availability="coming_next">Tell us what you need help deciding <span aria-hidden="true">→</span></button></article>
    <article><b>COMING NEXT</b><h3>Artificial Intelligence</h3><p>Practical adoption with judgment.</p><button type="button" class="os-text-link" data-library-decision="Artificial Intelligence" data-availability="coming_next">Tell us what you need help deciding <span aria-hidden="true">→</span></button></article>
    <article><b>COMING NEXT</b><h3>Practice Ownership</h3><p>Control, risk, and economics.</p><button type="button" class="os-text-link" data-library-decision="Practice Ownership" data-availability="coming_next">Tell us what you need help deciding <span aria-hidden="true">→</span></button></article>
    <article><b>COMING NEXT</b><h3>Leadership</h3><p>Clearer decisions with others.</p><button type="button" class="os-text-link" data-library-decision="Leadership" data-availability="coming_next">Tell us what you need help deciding <span aria-hidden="true">→</span></button></article>
  </div></div></section>

  <dialog class="os-request-modal" data-request-modal aria-labelledby="request-title"><form method="dialog" class="os-modal-card" data-request-form><button class="os-modal-close" value="cancel" aria-label="Close request panel">×</button><p class="os-eyebrow">COMING NEXT</p><h2 id="request-title" data-request-title>Contract</h2><p>This Decision Episode is still being developed. Your question helps determine what BOMSociety builds next.</p><label for="request-question">What would you most want help deciding?</label><p class="os-modal-hint">One useful question is enough. Optional context stays out of standard analytics.</p><textarea id="request-question" name="question" rows="3" maxlength="600" placeholder="Optional — do not include identifying details."></textarea><button type="submit" class="os-button">Submit my question <span aria-hidden="true">→</span></button><p class="os-request-confirmation" data-request-confirmation hidden aria-live="polite"></p></form></dialog>
  <section class="os-episode" id="compensation-pathway" hidden aria-labelledby="episode-title"><div class="shell">
    <div class="os-episode-label"><div><p class="os-eyebrow">FLAGSHIP DECISION EPISODE</p><h2 id="episode-title">Compensation, made legible.</h2></div><p>Move at the depth you need. Your progress stays private in this browser.</p></div>
    <ol class="os-steps" aria-label="Decision Episode steps"><li class="is-active" data-step="big">Big Picture</li><li data-step="brief">Brief Overview</li><li data-step="deep">Deep Dive</li><li data-step="calculator">Calculator</li><li data-step="checklist">Checklist</li><li data-step="action">Action Plan</li><li data-step="reflection">Reflection</li><li data-step="outcome">OUTCOME</li><li data-step="share">SHARE</li></ol>
    <article class="os-panel" data-panel="big"><p class="os-eyebrow">BIG PICTURE · 30 SECONDS</p><h2>A compensation number is not a compensation formula.</h2><div class="os-formula"><b>YOUR COMPENSATION</b><span>Guarantee</span><i>+</i><span>Productivity</span><i>+</i><span>Quality</span><i>+</i><span>Call / leadership</span><i>−</i><span>Unseen conditions</span></div><div class="os-insights"><p><b>01</b> The headline salary may only be the guarantee.</p><p><b>02</b> Thresholds and attribution determine what work pays.</p><p><b>03</b> Reconciliation tells you whether the formula works in practice.</p></div><div class="os-stat"><strong>One request can change the entire conversation.</strong><span>Ask for the full written formula and two recent reconciliation statements.</span></div><p class="os-transition">You understand the formula. Next, test the offer.</p><button type="button" class="os-button" data-next="brief">Continue to Brief Overview <span aria-hidden="true">→</span></button></article>
    <article class="os-panel" data-panel="brief" hidden><p class="os-eyebrow">BRIEF OVERVIEW · 2 MINUTES</p><h2>Same salary. Different economics.</h2><div class="os-offers"><div><span>OFFER A</span><b>$300k</b><p>Clear threshold · Quarterly reconciliation · Defined attribution</p></div><div><span>OFFER B</span><b>$300k</b><p>High threshold · Annual reconciliation · Unclear exclusions</p></div></div><p class="os-transition">You can now identify the terms that change compensation.</p><p class="os-action"><strong>Three questions to bring:</strong> What is the threshold? What is the conversion factor? What work is credited to me?</p><button type="button" class="os-button" data-next="deep">Work through the Deep Dive <span aria-hidden="true">→</span></button></article>
    <article class="os-panel" data-panel="deep" hidden><p class="os-eyebrow">DEEP DIVE · 5 MINUTES</p><h2>Turn a number into questions you can use.</h2><div class="os-deep"><div><h3>Before the conversation</h3><ol><li>Request the written formula and definitions.</li><li>Identify the threshold and conversion factor.</li><li>Clarify attribution, quality, call, and payment timing.</li><li>Ask how disagreements are resolved.</li></ol></div><div><h3>Common blind spots</h3><ul><li>Assuming the guarantee is the whole deal.</li><li>Missing work excluded from attribution.</li><li>Accepting undefined quality adjustments.</li><li>Waiting a year for reconciliation.</li></ul></div></div><p class="os-transition">You now have the framework. Turn it into action.</p><button type="button" class="os-button" data-next="calculator">Build my next-step checklist <span aria-hidden="true">→</span></button></article>
    <article class="os-panel" data-panel="calculator" hidden><p class="os-eyebrow">INTERACTIVE CALCULATOR</p><h2>Make the formula visible.</h2><div class="os-calculator"><label>Guaranteed compensation <input data-calc="guarantee" type="number" value="300000" min="0"></label><label>Credited wRVUs <input data-calc="units" type="number" value="6000" min="0"></label><label>Threshold wRVUs <input data-calc="threshold" type="number" value="5000" min="0"></label><label>Conversion factor <input data-calc="factor" type="number" value="55" min="0"></label><output data-calculator-result>Illustrative total: $355,000</output><small>Educational illustration only; actual terms and payment rules vary.</small></div><button type="button" class="os-button" data-next="checklist">Save your checklist <span aria-hidden="true">→</span></button></article>
    <article class="os-panel" data-panel="checklist" hidden><p class="os-eyebrow">CHECKLIST</p><h2>Leave with a clear request.</h2><label class="os-check"><input type="checkbox" data-action-check> Request the complete written compensation formula.</label><label class="os-check"><input type="checkbox" data-action-check> Ask for two recent reconciliation statements.</label><label class="os-check"><input type="checkbox" data-action-check> Confirm attribution, quality, and dispute terms.</label><button type="button" class="os-button" data-next="action">Build my action plan <span aria-hidden="true">→</span></button></article>
    <article class="os-panel" data-panel="action" hidden><p class="os-eyebrow">ACTION PLAN</p><h2>Your next conversation, prepared.</h2><p class="os-quote">“Please provide the productivity formula, threshold, conversion factor, attribution rules, quality measures, and reconciliation schedule in writing.”</p><button type="button" class="os-button" data-next="reflection">Record your confidence <span aria-hidden="true">→</span></button></article>
    <article class="os-panel" data-panel="reflection" hidden><p class="os-eyebrow">REFLECTION</p><h2>What changed in your understanding?</h2><p>Save a private confidence check. It is stored only in this browser.</p><div class="os-confidence" data-confidence-options aria-label="Confidence from zero to ten"></div><button type="button" class="os-button" data-next="outcome">See your career win <span aria-hidden="true">→</span></button></article>
    <article class="os-panel" data-panel="outcome" hidden><p class="os-eyebrow">YOUR CAREER WIN</p><h2>You now know exactly what compensation formula to request.</h2><div class="os-career-win"><span>✓</span><p>Estimated impact: <strong>potentially six figures over your career.</strong><br><small>That is a possibility—not a promise. The next step is a better question.</small></p></div><button type="button" class="os-button" data-next="share">Help a colleague <span aria-hidden="true">→</span></button></article>
    <article class="os-panel" data-panel="share" hidden><p class="os-eyebrow">YOUR NEXT MOVE</p><h2>Ask for the complete written compensation formula before evaluating the offer.</h2><div class="os-next-actions"><button type="button" class="os-text-link" data-save-action>Save this action</button><button type="button" class="os-text-link" data-share>Send to a colleague</button><button type="button" class="os-text-link" data-reflection>Record what I plan to do</button><a class="os-text-link" href="#compensation-pathway">Return after the conversation</a></div><div class="os-share-context"><h3>Know someone reviewing an offer?</h3><p>Send them the compensation framework before their next conversation.</p><button type="button" class="os-button" data-share>Send to a colleague <span aria-hidden="true">→</span></button></div></article>
  </div></section>


  <section class="os-enterprise" aria-labelledby="enterprise-title"><div class="shell os-enterprise-grid"><div><p class="os-eyebrow">WHY THIS GETS BETTER</p><h2 id="enterprise-title">Every physician decision makes the next physician's guidance better—without exposing the physician.</h2><p>Guidance improves through anonymous, aggregated patterns—not individual profiles. Physicians remain free, and individual physician data is never sold.</p><div class="os-trust-list"><span>Anonymous by design</span><span>Aggregated before insight</span><span>Transparent about what is next</span></div></div><div class="os-enterprise-actions"><p><strong>Built physician-first.</strong> Future intelligence is in development, with governance before commercial use.</p><a class="os-button" href="{{@site.url}}/enterprise/">See how this gets better <span aria-hidden="true">→</span></a><a class="os-text-link" href="{{@site.url}}/privacy/">See how privacy works <span aria-hidden="true">→</span></a></div></div></section>
</main>
