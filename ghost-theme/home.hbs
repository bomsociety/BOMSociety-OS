{{!< default}}
<main class="decision-os" id="main" data-track-section="physician-product">
  <section class="os-hero" aria-labelledby="os-hero-title">
    <div class="os-hero-grid">
      <div class="os-hero-copy">
        <p class="os-kicker">MISSION</p>
        <p class="os-hero-promise">Respect your time.<br><strong>Earn your trust.</strong><br>Improve your decisions.</p>
        <h1 id="os-hero-title">One business decision could change your career.</h1>
        <button type="button" class="os-button" data-start-decision data-intelligence-action="compensation_module_selected">FIND MY BIGGEST OPPORTUNITY <span aria-hidden="true">→</span></button>
        <div class="os-opportunity-depths os-hero-depths" id="opportunity" aria-label="Choose content depth">
          <button type="button" data-opportunity-depth="quick"><b>⚡ BIG PICTURE</b><span>30 sec</span></button>
          <button type="button" data-opportunity-depth="brief"><b>🎯 BRIEF OVERVIEW</b><span>2 min</span></button>
          <button type="button" data-opportunity-depth="deep"><b>🚀 DEEP DIVE</b><span>5 min</span></button>
        </div>
      </div>
      <div class="os-score-column">
        <section class="os-score-block" aria-label="Your current physician ranking">
          <div><p>YOU</p><strong>TOP <span data-ranking>18</span>%</strong><b>OF PHYSICIAN DECISION MAKERS</b></div>
          <div class="os-score-meta"><span><b data-ranking-change>+4</b>%</span><button type="button" data-score-toggle aria-expanded="false" aria-controls="score-context">How calculated</button></div>
          <p class="os-score-context" id="score-context" hidden>Private ranking reflects decision practice, demonstrated understanding, and applied learning. Each experience counts once.</p>
        </section>
      </div>
      <aside class="os-intelligence os-intelligence-hero" id="live-intelligence" aria-label="Enterprise decision intelligence"><p class="os-kicker">Decision Intelligence™</p><h2>Enterprise signals, built for action.</h2><p class="os-stream-status"><i></i> LIVE INTELLIGENCE</p><ul><li>Compensation Intelligence™</li><li>Recruiting Signals™</li><li>Practice Transition Intelligence™</li><li>Physician AI Adoption Index™</li><li>Leadership Intelligence™</li><li>Private Equity Intelligence™</li><li>Specialty Benchmarking™</li><li>Physician Decision API™</li></ul><button type="button" class="os-enterprise" data-enterprise-preview>EXPLORE ENTERPRISE PREVIEW →</button></aside>
    </div>
  </section>

  <section class="os-workspace" id="questions" aria-label="Physician decision workspace">
    <aside class="os-decision-questions"><p class="os-kicker">CHOOSE A DECISION</p><h2>What deserves your attention?</h2><div class="os-question-grid"><button class="os-question is-selected" type="button" data-module-select="paid-more" data-intelligence-action="compensation_module_selected"><strong>Are you getting paid what you're worth?</strong><span>→</span></button><button class="os-question" type="button" data-intelligence-action="contract_tension_selected"><strong>Would you sign your contract again today?</strong><span>→</span></button><button class="os-question" type="button" data-intelligence-action="ai_tension_selected"><strong>Could AI give you one clinic back every week?</strong><span>→</span></button><button class="os-question" type="button" data-intelligence-action="ownership_tension_selected"><strong>Should you own your practice—or stay employed?</strong><span>→</span></button><button class="os-question" type="button" data-intelligence-action="negotiation_tension_selected"><strong>The contract mistake costing physicians six figures.</strong><span>→</span></button></div></aside>
    <section class="os-today" aria-labelledby="today-title"><div class="os-today-head"><div><p class="os-kicker">YOUR DECISION PATH</p><h2 id="today-title">GET PAID MORE</h2><p>One useful insight now. A stronger decision next.</p></div><div class="os-readiness"><span>READINESS</span><b data-readiness>42%</b></div></div><div class="os-path" aria-label="Decision learning path"><button type="button" class="is-active" data-depth="quick"><b>⚡ BIG PICTURE</b><span>30 sec</span></button><button type="button" data-depth="brief"><b>🎯 BRIEF OVERVIEW</b><span>~2 min</span></button><button type="button" data-depth="deep"><b>🚀 DEEP DIVE</b><span>~5 min</span></button></div><div class="os-learning-panel" data-module-content></div><div class="os-action-rail"><button type="button" data-open-check>KNOWLEDGE CHECK <span>Test the pattern →</span></button><button type="button" data-next-decision>BASED ON YOUR PROGRESS <span>Your next decision →</span></button></div></section>
  </section>

  <section class="os-live-strip" aria-label="Live homepage intelligence"><article><span>PHYSICIANS ONLINE</span><b>1,284</b></article><article><span>MOST ACTIVE TOPIC</span><b>Getting paid what you're worth</b></article><article><span>FASTEST GROWING</span><b>AI adoption</b></article><article><span>HIGHEST RATED</span><b>Contract review</b></article></section>
  <section class="os-completion" data-completion hidden aria-live="polite"></section>
  <section class="os-community" id="community" aria-labelledby="community-title"><div><p class="os-kicker">COMMUNITY INTELLIGENCE</p><h2 id="community-title">Progress compounds.</h2><p>See what physicians are learning from each other—anonymously. Your individual information is never sold.</p></div><div class="os-community-stats"><article><b>21,487</b><span>physicians made better decisions</span></article><article><b>Compensation</b><span>most selected decision</span></article><article><b>AI</b><span>fastest growing topic</span></article><article><b>Employment Contracts</b><span>highest rated topic</span></article></div></section>
  <section class="os-next" aria-labelledby="next-title"><p class="os-kicker">BASED ON YOUR PROGRESS...</p><h2 id="next-title">Your highest impact next decision is <em>Would you sign your contract again today?</em></h2><div><span>ESTIMATED CAREER IMPACT <b>★★★★★</b></span><span>ESTIMATED TIME <b>2 minutes</b></span><button type="button" data-next-decision>START NEXT DECISION →</button></div></section>
</main>
