<article class="article-card">
  {{#if feature_image}}
    <a class="article-card-image" href="{{url}}" aria-label="{{title}}">
      <img
        srcset="{{img_url feature_image size="s"}} 320w,
                {{img_url feature_image size="m"}} 640w,
                {{img_url feature_image size="l"}} 960w"
        sizes="(max-width: 760px) 100vw, 33vw"
        src="{{img_url feature_image size="m"}}"
        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
        loading="lazy">
    </a>
  {{/if}}
  <div class="article-card-body">
    <div class="article-meta">
      <span>{{primary_tag.name}}</span>
      <span>{{reading_time}}</span>
    </div>
    <h3><a href="{{url}}">{{title}}</a></h3>
    <p>{{excerpt words="24"}}</p>
    <a class="text-link" href="{{url}}">Read article →</a>
  </div>
</article>
