{{!< default}}
{{#post}}
<article class="post-wrap {{post_class}}">
  <header class="post-header shell-narrow">
    {{#if primary_tag}}<a class="post-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>{{/if}}
    <h1>{{title}}</h1>
    {{#if custom_excerpt}}<p class="post-excerpt">{{custom_excerpt}}</p>{{/if}}
    <div class="post-meta"><span>{{reading_time}}</span><span>Updated {{date updated_at format="MMMM D, YYYY"}}</span>{{#if authors}}<span>By {{authors}}</span>{{/if}}</div>
  </header>
  {{#if feature_image}}<figure class="post-image shell-wide"><img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">{{#if feature_image_caption}}<figcaption>{{feature_image_caption}}</figcaption>{{/if}}</figure>{{/if}}
  <div class="post-body shell-narrow">
    <aside class="decision-rail" aria-label="Choose reading depth"><span>LESSON DEPTH</span><a href="#bottom-line" data-depth-select="30_seconds">30 sec</a><a href="#decision-brief" data-depth-select="2_minutes">2 min</a><a href="#complete-guide" data-depth-select="5_minutes">5 min</a></aside>
    {{> level-up-components}}
    <div class="gh-content">{{content}}</div>
  </div>
  <footer class="post-footer shell-narrow"><div class="post-principle"><strong>Respect your time. Earn your trust. Improve your decisions.</strong><p>BOMSociety content is educational and does not replace individualized legal, financial, tax, or medical advice.</p></div></footer>
  {{#if primary_tag}}{{#get "posts" filter="primary_tag:{{primary_tag.slug}}+id:-{{id}}" limit="3" include="tags,authors"}}<section class="related section-soft" data-track-section="related-decisions"><div class="shell"><p class="eyebrow">RELATED DECISIONS / NEXT LEVEL</p><h2>Continue when it is useful.</h2><div class="article-grid">{{#foreach posts}}{{> article-card}}{{/foreach}}</div></div></section>{{/get}}{{/if}}
</article>
{{/post}}
