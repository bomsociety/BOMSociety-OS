{{!< default}}{{#post}}<article class="post-template"><header class="post-header wrap post-wrap"><p class="eyebrow">{{primary_tag.name}}</p><h1>{{title}}</h1>{{#if custom_excerpt}}<p class="post-excerpt">{{custom_excerpt}}</p>{{/if}}<div class="post-meta"><span>{{reading_time}}</span><span>Updated {{date updated_at format="MMMM D, YYYY"}}</span></div></header>{{#if feature_image}}<figure class="post-feature wrap"><img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"></figure>{{/if}}<div class="gh-content post-wrap wrap">{{content}}</div></article>{{/post}}