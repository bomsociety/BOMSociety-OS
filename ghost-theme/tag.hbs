{{!< default}}
<section class="section">
  <div class="wrap">
    {{#tag}}
      <p class="eyebrow">TOPIC</p>
      <h1>{{name}}</h1>
      {{#if description}}<p class="archive-description">{{description}}</p>{{/if}}
    {{/tag}}
    <div class="ghost-card-grid">{{#foreach posts}}{{> article-card}}{{/foreach}}</div>
    {{pagination}}
  </div>
</section>
