{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bomsociety.org/knowledge/schemas/claim.schema.json",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "knowledgeObjectId", "statement", "evidenceLevel", "corroborationScore", "confidence", "reviewer", "version", "createdAt", "updatedAt"],
  "properties": {
    "id": { "$ref": "common.schema.json#/$defs/uuid" },
    "knowledgeObjectId": { "$ref": "common.schema.json#/$defs/uuid" },
    "statement": { "type": "string", "minLength": 1 },
    "evidenceLevel": { "enum": ["none", "emerging", "supported", "strong"] },
    "corroborationScore": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reviewer": { "type": "string", "minLength": 1 },
    "version": { "$ref": "common.schema.json#/$defs/version" },
    "createdAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "updatedAt": { "$ref": "common.schema.json#/$defs/timestamp" }
  }
}
